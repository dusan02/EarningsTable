parameters:
    level: 5
    paths:
        - .
    excludePaths:
        - Tests/
        - docs/
        - archive/ (?)
        - vendor/ (?)
    ignoreErrors:
        - '#Call to an undefined method [a-zA-Z0-9\\_]+::[a-zA-Z0-9\\_]+#'
        - '#Access to an undefined property [a-zA-Z0-9\\_]+::\$[a-zA-Z0-9\\_]+#'
