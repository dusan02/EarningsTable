{
    "name": "earnings-table/dashboard",
    "description": "Real-Time Stock Earnings Dashboard with API integrations",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "EarningsTable Team",
            "email": "team@earningstable.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "ext-curl": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "*",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "EarningsTable\\": "src/"
        },
        "files": [
            "config/config.php",
            "common/UnifiedApiWrapper.php",
            "common/UnifiedLogger.php",
            "common/UnifiedCronManager.php",
            "common/UnifiedValidator.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "EarningsTable\\Tests\\": "Tests/"
        }
    },
    "scripts": {
        "test": "php Tests/github_actions_test.php",
        "test-all": "php Tests/*.php",
        "cs": "phpcs --standard=PSR12 --extensions=php .",
        "stan": "phpstan analyse --level=5 .",
        "deploy": "tar -czf deployment.tar.gz --exclude='.git' --exclude='Tests' --exclude='docs' ."
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
