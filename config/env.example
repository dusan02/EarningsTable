# 🌐 EarningsTable Environment Configuration
# Citlivé údaje - NIKDY necommitovať do Git!

# 🗄️ Database Configuration
DB_HOST=localhost
DB_NAME=earnings_db
DB_USER=root
DB_PASS=

# 🔑 API Keys
POLYGON_API_KEY=your_polygon_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
YAHOO_API_KEY=your_yahoo_api_key_here

# 🌍 Environment
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# 🔒 Security
APP_KEY=your_32_character_random_key_here
SESSION_SECURE=false
COOKIE_SECURE=false

# 📊 API Limits
API_RATE_LIMIT=100
API_RATE_WINDOW=60

# 🔑 Polygon API Limits
POLYGON_RATE_LIMIT=100
POLYGON_RATE_WINDOW=60

# 🔑 Finnhub API Limits
FINNHUB_RATE_LIMIT=60
FINNHUB_RATE_WINDOW=60

# 🔑 Yahoo API Limits
YAHOO_RATE_LIMIT=100
YAHOO_RATE_WINDOW=60

# 📝 Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ⏰ Timezone
TIMEZONE=Europe/Prague
