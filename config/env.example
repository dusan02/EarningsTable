# EarningsTable Environment Configuration
# Konfigurácia prostredia pre EarningsTable

# Application Environment
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.mydreams.cz

# Database Configuration
DB_HOST=localhost
DB_NAME=earnings_table
DB_USER=root
DB_PASS=

# API Keys
FINNHUB_API_KEY=your_finnhub_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here

# Application Settings
TIMEZONE=America/New_York
LOG_LEVEL=INFO

# Rate Limiting
API_RATE_LIMIT_DELAY=0.1
MAX_CONCURRENT_REQUESTS=10

# Development Settings (uncomment for development)
# APP_ENV=development
# APP_DEBUG=true
# TIMEZONE=Europe/Prague
# LOG_LEVEL=DEBUG
# DB_NAME=earnings_table_dev
# APP_URL=http://localhost:8080
